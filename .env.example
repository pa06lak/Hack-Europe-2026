# Orbit — environment template. Copy to .env and fill in. NEVER commit real keys.
# Source of truth for what each key is: wiki/build/stack.md

# --- core (4 load-bearing partner techs) ---
VOICEAI_API_KEY=         # SLNG voice agents — Bearer (https://app.slng.ai/api-keys)
SLNG_REGION=eu-central   # us-east | eu-central | ap-south
SLNG_WEBHOOK_URL=        # public URL to voice service POST /slng/call-end (e.g. ngrok); set before create-agent
SLNG_AGENT_ID=           # set after `npm run create-agent` (enables outbound calls)
ATTIO_API_KEY=           # bearer token; OR configure Attio MCP instead of a raw key
GEMINI_API_KEY=          # structures the call into a lead JSON + drafts copy

N8N_BASE_URL=            # e.g. https://<you>.app.n8n.cloud
N8N_WEBHOOK_URL=         # the n8n trigger URL Attio's automation POSTs to

# --- WhatsApp (pick ONE path; delete the other) ---
# Path A: Twilio WhatsApp sandbox (fastest, no business verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=    # e.g. whatsapp:+14155238886 (Twilio sandbox number)
# Path B: WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- demo recipient (our own number) ---
DEMO_PHONE=              # E.164, e.g. +44... — where outreach lands in the demo

# --- stretch partners (only if adopted) ---
SUPERLINKED_API_KEY=
SUPERLINKED_URL=
TAVILY_API_KEY=

# --- stretch channels ---
TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
